generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActionType {
  transform
  filter
  http_enrichment
}

enum JobStatus {
  pending
  processing
  completed
  failed
  dead
}

enum DeliveryStatus {
  success
  failed
}

model Pipeline {
  id           String      @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  source_id    String      @unique @default(uuid()) @db.Uuid
  action_type  ActionType
  action_config Json       @default(dbgenerated("'{}'::jsonb"))
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  subscribers  Subscriber[]
  jobs         Job[]

  @@index([source_id])
}

model Subscriber {
  id          String   @id @default(uuid()) @db.Uuid
  pipeline_id String   @db.Uuid
  url         String
  secret      String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  pipeline    Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  deliveries  DeliveryAttempt[]

  @@index([pipeline_id])
}

model Job {
  id               String    @id @default(uuid()) @db.Uuid
  pipeline_id      String    @db.Uuid
  status           JobStatus
  payload          Json
  processed_payload Json?
  attempts         Int       @default(0)
  max_attempts     Int
  last_error       String?
  scheduled_at     DateTime  @default(now())
  started_at       DateTime?
  completed_at     DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  pipeline         Pipeline  @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  delivery_attempts DeliveryAttempt[]

  @@index([pipeline_id, created_at(sort: Desc)])
  @@index([status, scheduled_at])
}

model DeliveryAttempt {
  id            String         @id @default(uuid()) @db.Uuid
  job_id        String         @db.Uuid
  subscriber_id String         @db.Uuid
  status        DeliveryStatus
  status_code   Int?
  response_body String?
  error_message String?
  attempt_number Int
  duration_ms   Int
  attempted_at  DateTime       @default(now())

  job           Job            @relation(fields: [job_id], references: [id], onDelete: Cascade)
  subscriber    Subscriber     @relation(fields: [subscriber_id], references: [id], onDelete: Cascade)

  @@index([job_id])
  @@index([subscriber_id])
}
